; PJSIP Configuration - Generated by Ansible for Asterisk 22.x

[transport-udp]
type=transport
protocol=udp
bind=0.0.0.0:5060

[transport-tcp]
type=transport
protocol=tcp
bind=0.0.0.0:5060

{% for user in pjsip_users %}
; ============================================
; Endpoint for {{ user.callerid }} ({{ user.name }})
; ============================================
[{{ user.name }}]
type=endpoint
context=internal
disallow=all
allow=ulaw,alaw
auth={{ user.name }}-auth
aors={{ user.name }}
callerid="{{ user.callerid}}" <{{ user.name }}>

[{{ user.name }}-auth]
type=auth
auth_type=userpass
password={{ user.secret }}
username={{ user.name }}

[{{ user.name }}]
type=aor
max_contacts=5
qualify_frequency=30
{% endfor %}
